{
  "name": "xiaohongshu-content-capture-desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Desktop app for user-authorized Xiaohongshu creator content briefs.",
  "author": "taohuang1998th-droid",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "install-browsers": "playwright install chromium",
    "prepare-browsers": "node scripts/prepare-playwright-browsers.js",
    "build:mac": "npm run check && npm run prepare-browsers && electron-builder --mac dmg",
    "build:win": "npm run check && npm run prepare-browsers && electron-builder --win nsis --x64",
    "check": "node --check src/main.js && node --check src/preload.js && node --check src/renderer/renderer.js && node --check scripts/prepare-playwright-browsers.js"
  },
  "build": {
    "appId": "com.taohuang.xiaohongshu-content-capture",
    "productName": "小红书内容简报",
    "asar": true,
    "directories": {
      "output": "dist"
    },
    "files": [
      "package.json",
      "src/**/*",
      "node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "../skills/xiaohongshu-content-capture",
        "to": "skill",
        "filter": [
          "**/*",
          "!scripts/__pycache__/**",
          "!**/*.pyc"
        ]
      },
      {
        "from": "build-resources/ms-playwright",
        "to": "ms-playwright",
        "filter": [
          "**/*"
        ]
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        "dmg"
      ],
      "identity": null
    },
    "dmg": {
      "artifactName": "${productName}-${version}-${arch}.${ext}",
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "${productName}-${version}-win-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "小红书内容简报"
    }
  },
  "dependencies": {
    "playwright": "^1.45.3"
  },
  "devDependencies": {
    "electron": "^43.0.0",
    "electron-builder": "^26.0.12"
  }
}
